# ─────────────────────────────────────────────────────────────────────────────
# BNPL Backend – Environment Variables
# Copy this file to .env and fill in the real values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development                      # development | production

# ── Database (PostgreSQL / Neon) ──────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB_NAME?sslmode=require

# ── JWT – Access token (1 h) + Refresh token (7 d) ───────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET

# ── Frontend origin (used for CORS and email links) ───────────────────────────
FRONTEND_URL=http://localhost:5173

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_REPLACE_WITH_RESEND_API_KEY
EMAIL_FROM=noreply@yourdomain.com

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_STRIPE_SECRET_KEY
# REQUIRED – obtain from Stripe Dashboard > Webhooks > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_STRIPE_WEBHOOK_SECRET
# Optional – Stripe Connect: ID of the connected merchant account to transfer funds to
STRIPE_CONNECTED_ACCOUNT_ID=acct_REPLACE_IF_USING_STRIPE_CONNECT
# Optional – platform fee percentage retained before transferring to merchant (default 5)
STRIPE_PLATFORM_FEE_PERCENT=5

# ── Cron jobs (Vercel Cron / external scheduler) ──────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Set the same value in your Vercel project environment as CRON_SECRET.
CRON_SECRET=REPLACE_WITH_RANDOM_SECRET

# ── Host API (external booking intake) ───────────────────────────────────────
HOST_API_KEY=REPLACE_WITH_RANDOM_API_KEY
