generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  MASTER_SELLER
  NORMAL_SELLER
  CUSTOMER
}

enum OperatorStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum BookingStatus {
  PENDING
  ACCEPTED
  REJECTED
  ALTERNATIVE_SUGGESTED
  PENDING_PAYMENT
  PAID
  OVERDUE
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PENDING_VERIFICATION
  PAID
  FAILED
  OVERDUE
}

enum PaymentMethod {
  PENDING
  PAYPAL
  STRIPE
  DUITNOW
  SPAY
  BANK_TRANSFER
  CASH
}

enum ReceiptStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InvoiceStatus {
  GENERATED
  SENT
  PAID
  CANCELLED
}

enum EmailStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum OperatorAccessLevel {
  OWNER
  STAFF
}

model User {
  id       Int      @id @default(autoincrement())
  userCode String   @unique
  name     String
  email    String   @unique
  password String
  role     UserRole @default(CUSTOMER)

  phone           String?
  profileImageUrl String? @db.Text

  notifyBookingUpdates Boolean @default(true)
  notifyPaymentReminders Boolean @default(true)
  notifyInvoices Boolean @default(true)
  notifyPromotions Boolean @default(false)

  operatorAccessLevel OperatorAccessLevel?

  operatorId Int?
  operator   Operator? @relation(fields: [operatorId], references: [id])

  bookings      Booking[]
  notifications Notification[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userCode])
  @@index([operatorId])
  @@index([role])
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  tokenHash String   @unique
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Operator {
  id           Int            @id @default(autoincrement())
  operatorCode String         @unique
  companyName  String
  email        String         @unique
  phone        String?
  logoUrl      String?
  status       OperatorStatus @default(ACTIVE)
  stripeAccountId String?

  users    User[]
  bookings Booking[]
  configs  BNPLConfig[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([operatorCode])
  @@index([status])
}

model Booking {
  id          Int    @id @default(autoincrement())
  hostBookingRef String?
  bookingCode String @unique
  
  customerId Int
  customer   User @relation(fields: [customerId], references: [id])

  operatorId Int
  operator   Operator @relation(fields: [operatorId], references: [id])

  serviceName String
  serviceType String?

  bookingDate DateTime
  pickupDate  DateTime?
  returnDate  DateTime?
  location    String?

  totalAmount Decimal       @db.Decimal(10, 2)
  status      BookingStatus @default(PENDING)

  paymentDeadline DateTime?

  alternativeServiceName String?
  alternativePrice       Decimal? @db.Decimal(10, 2)
  alternativePickupDate  DateTime?
  alternativeReturnDate  DateTime?
  alternativeReason      String?
  alternativeSuggestedAt DateTime?
  alternativeUsed        Boolean  @default(false)

  payment Payment?
  receipt Receipt?
  invoice Invoice?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingCode])
  @@index([customerId])
  @@index([operatorId])
  @@index([status])
  @@index([paymentDeadline])
}

model Payment {
  id Int @id @default(autoincrement())

  bookingId Int     @unique
  booking   Booking @relation(fields: [bookingId], references: [id])

  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod @default(PENDING)
  status        PaymentStatus @default(UNPAID)
  paidAt        DateTime?
  transactionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([method])
}

model Receipt {
  id Int @id @default(autoincrement())

  bookingId Int     @unique
  booking   Booking @relation(fields: [bookingId], references: [id])

  imageUrl String
  status   ReceiptStatus @default(PENDING)
  remarks  String?

  uploadedAt DateTime @default(now())
  verifiedAt DateTime?

  @@index([status])
}

model Invoice {
  id Int @id @default(autoincrement())

  bookingId Int     @unique
  booking   Booking @relation(fields: [bookingId], references: [id])

  invoiceNo String        @unique
  amount    Decimal       @db.Decimal(10, 2)
  status    InvoiceStatus @default(GENERATED)
  pdfUrl    String?

  issuedAt DateTime @default(now())
  sentAt   DateTime?

  @@index([invoiceNo])
  @@index([status])
}

model Notification {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id])

  title   String
  message String
  type    String
  isRead  Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

model BNPLConfig {
  id Int @id @default(autoincrement())

  operatorId Int
  operator   Operator @relation(fields: [operatorId], references: [id])

  paymentDeadlineDays Int     @default(3)
  allowReceiptUpload  Boolean @default(true)
  autoCancelOverdue   Boolean @default(true)

  // Operator booking action settings
  bookingResponseDeadlineMinutes      Int     @default(120)
  autoRejectInactiveBooking           Boolean @default(true)
  reminderBeforeAutoRejectMinutes     Int     @default(30)

  // Payment settings
  acceptedPaymentMethods Json?
  manualPaymentNote      String?

  // Notification settings
  operatorReminderBeforeAutoRejectMinutes Int     @default(30)
  enableOperatorReminderAlerts            Boolean @default(true)

  // Email branding
  invoiceLogoUrl    String?
  invoiceFooterText String?
  
  // Rejection email custom text
  bookingRejectedEmailText String?
  autoRejectedEmailText    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([operatorId])
}

model AuditLog {
  id Int @id @default(autoincrement())

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  action     String
  entityType String
  entityId   String?
  details    Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entityType])
  @@index([entityId])
}

model EmailLog {
  id Int @id @default(autoincrement())

  toEmail String
  subject String
  type    String
  status  EmailStatus @default(PENDING)

  relatedEntityType String?
  relatedEntityId   String?

  userId Int?
  error  String?

  createdAt DateTime @default(now())
  sentAt    DateTime?
  updatedAt DateTime @updatedAt

  @@index([toEmail])
  @@index([type])
  @@index([status])
  @@index([relatedEntityType])
  @@index([relatedEntityId])
  @@index([userId])
}

model HostBookingIntent {
  id Int @id @default(autoincrement())

  token          String  @unique
  operatorId     Int
  operatorCode   String
  hostBookingRef String
  customerName   String
  customerEmail  String

  serviceName String
  serviceType String?
  bookingDate DateTime
  pickupDate  DateTime?
  returnDate  DateTime?
  location    String?
  totalAmount Decimal  @db.Decimal(10, 2)

  payload Json?

  status           String   @default("PENDING")
  claimedByUserId  Int?
  claimedBookingId Int?
  expiresAt        DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([hostBookingRef])
  @@index([customerEmail])
  @@index([status])
  @@index([expiresAt])
}

model CronJobRun {
  id Int @id @default(autoincrement())

  jobType String
  status  String @default("SUCCESS")

  triggeredByUserId Int?
  triggerSource      String?

  startedAt  DateTime @default(now())
  finishedAt DateTime?

  affectedCount Int @default(0)
  result        Json?
  error         String?

  createdAt DateTime @default(now())

  @@index([jobType])
  @@index([status])
  @@index([startedAt])
  @@index([triggeredByUserId])
}